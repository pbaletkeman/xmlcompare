<?xml version="1.0" encoding="UTF-8"?>
<!--
  Sample document using XML namespaces.
  Pair with catalog_ns_b.xml which uses a different namespace prefix
  but the same local names.

  Run with -ignore-namespaces to treat them as equal:
    python xmlcompare.py -files catalog_ns_a.xml catalog_ns_b.xml -ignore-namespaces
-->
<cat:catalog xmlns:cat="http://example.com/catalog/v1"
             xmlns:prod="http://example.com/product/v1">
  <cat:product id="P100">
    <prod:name>Laptop Pro</prod:name>
    <prod:price currency="USD">1299.00</prod:price>
    <prod:inStock>true</prod:inStock>
  </cat:product>
  <cat:product id="P101">
    <prod:name>Wireless Mouse</prod:name>
    <prod:price currency="USD">29.99</prod:price>
    <prod:inStock>false</prod:inStock>
  </cat:product>
</cat:catalog>
